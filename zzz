<div id="view-senior" class="view-content">
    <div class="flex w-full h-full gap-6 items-stretch">
        
        <div class="w-80 bg-white border border-gray-200 flex flex-col shrink-0 shadow-sm">
            <div class="p-5 border-b-2 border-gold bg-navy-bg text-white">
                <span class="text-[9px] font-black uppercase tracking-[3px] text-gold">The Docket</span>
                <h3 class="text-md font-black uppercase mt-1">Pending Decrees</h3>
            </div>
            <div id="docket-feed" class="flex-1 overflow-y-auto p-3 space-y-2 bg-gray-50">
                <div class="p-3 border-l-4 border-red-600 bg-white shadow-sm cursor-pointer hover:bg-red-50 transition-all group" onclick="loadSovereignCase('Global Logistics', 4, 'B+', 7)">
                    <div class="flex justify-between items-center">
                        <span class="text-[10px] font-black text-blue-steel uppercase">Global Logistics</span>
                        <span class="text-[7px] font-black bg-red-600 text-white px-1.5 py-0.5 animate-pulse">CRITICAL</span>
                    </div>
                    <div class="flex justify-between mt-2">
                        <span class="text-[8px] font-bold text-gray-400">SLA: 00:04:12</span>
                        <span class="text-[8px] font-black text-red-600 uppercase opacity-0 group-hover:opacity-100">Review Case →</span>
                    </div>
                </div>

                <div class="p-3 border-l-4 border-gold bg-white shadow-sm cursor-pointer hover:bg-gray-50 transition-all group" onclick="loadSovereignCase('Alpha Hedge', 3, 'A-', 4)">
                    <div class="flex justify-between items-center">
                        <span class="text-[10px] font-black text-blue-steel uppercase">Alpha Hedge Fund</span>
                        <span class="text-[7px] font-black bg-gold text-navy-bg px-1.5 py-0.5">ESCALATED</span>
                    </div>
                    <div class="flex justify-between mt-2">
                        <span class="text-[8px] font-bold text-gray-400">SLA: 01:15:30</span>
                        <span class="text-[8px] font-black text-gold uppercase opacity-0 group-hover:opacity-100">Review Case →</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex-1 flex items-center justify-center">
            <div id="sovereign-card-display" class="senior-card w-full max-w-4xl">
                <div id="empty-state" class="py-20 text-center">
                    <svg viewBox="0 0 100 100" class="w-16 h-16 mx-auto mb-6 fill-gray-200">
                        <path d="M50 5L15 25V50C15 72.1 30.1 91.5 50 95C69.9 91.5 85 72.1 85 50V25L50 5Z"/>
                    </svg>
                    <p class="text-[10px] font-black uppercase text-gray-300 tracking-[5px]">Select Case from Docket to Issue Decree</p>
                </div>

                <div id="active-sovereign-case" class="hidden">
                    <header class="mb-8 border-b pb-4 flex justify-between items-end">
                        <div>
                            <span class="text-[9px] font-black text-gold uppercase tracking-[3px]">Institutional Risk Profile</span>
                            <h2 id="sov-entity-name" class="text-3xl font-black uppercase text-blue-steel">---</h2>
                        </div>
                        <div class="text-right">
                            <span class="text-[8px] font-black text-gray-300 uppercase">Master Registry</span>
                            <div class="text-[10px] font-black text-blue-steel">MC-DECREE-2026-X</div>
                        </div>
                    </header>

                    <div class="grid grid-cols-3 gap-8 mb-10">
                        <div class="border-l-2 border-gold pl-4">
                            <span class="header-label">Regulatory Exposure</span>
                            <div class="flex items-end gap-2">
                                <span id="sov-exposure" class="text-2xl font-black text-blue-steel">--</span>
                                <span class="text-[10px] font-bold text-gray-300 mb-1">/ 10</span>
                            </div>
                        </div>
                        <div class="border-l-2 border-gold pl-4">
                            <span class="header-label">Legal Immunity Grade</span>
                            <div id="sov-grade" class="text-2xl font-black text-blue-steel">--</div>
                        </div>
                        <div class="border-l-2 border-gold pl-4">
                            <span class="header-label">Firm Precedent</span>
                            <div id="sov-precedent" class="text-2xl font-black text-blue-steel">MATCH</div>
                        </div>
                    </div>

                    <div class="bg-gray-50 p-6 border border-gray-100 mb-8">
                        <span class="header-label">Sovereign Decree / Learning Opportunity</span>
                        <p class="text-[11px] leading-relaxed italic text-gray-500 mt-2">
                            Reviewing Analyst rationale against weighted metrics. Senior Decree will override or confirm based on the Institutional Risk Appetite.
                        </p>
                    </div>

                    <div class="flex gap-4">
                        <button class="btn-escalate" onclick="openSeniorMasterclass()">Review Senior Precedent</button>
                        <button class="btn-authorize" onclick="alert('SOVEREIGN DECREE ISSUED')">Issue Master Decree</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    function loadSovereignCase(name, tier, grade, exposure) {
        document.getElementById('empty-state').classList.add('hidden');
        document.getElementById('active-sovereign-case').classList.remove('hidden');
        
        document.getElementById('sov-entity-name').innerText = name;
        document.getElementById('sov-grade').innerText = grade;
        document.getElementById('sov-exposure').innerText = "0" + exposure;
        
        // Visual polish for Tier 4 in the Command Card
        const card = document.querySelector('.senior-card');
        card.style.borderColor = (tier === 4) ? '#991b1b' : '#F5C518';
    }
</script>
